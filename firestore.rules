rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // A user can only read/write their own profile document (id == uid).
    match /user/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Birthdays are owned via the `uid` field.
    match /birthday/{birthdayId} {
      allow read, update, delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }

    // Scanned books are owned via the `uid` field.
    match /books/{bookId} {
      allow read, update, delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }

    // Categories are shared across users (referenced by id on the user doc):
    // any signed-in user may read them and create new ones.
    match /category/{categoryId} {
      allow read, create: if request.auth != null;
    }
  }
}
